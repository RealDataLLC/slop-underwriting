{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Python API (FastAPI)",
      "runtimeExecutable": ".venv/bin/python3",
      "runtimeArgs": ["-m", "uvicorn", "api.main:app", "--reload", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000,
      "autoPort": false
    }
  ]
}
